generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TransactionLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  chainId      Int
  fromAddress  String
  toAddress    String
  value        String
  calldata     String
  verdict      String
  severity     String
  score        Float
  findingsJson String
  effectsJson  String
  metadataJson String
  actorAddress String?
}

model ComplianceNullifier {
  nullifier String   @id
  policy    String
  createdAt DateTime @default(now())
}

model TransactionFeedback {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  transactionId String?
  actorAddress String
  verdict      String
  notes        String?
}
